rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions (Phase 3 & Pillars)
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'puspharaj.m2003@gmail.com' &&
        request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@\\:\\~\\+]+$');
    }

    // Validation Blueprint for UserMetadata (Pillar 2)
    function isValidUserMetadata(data) {
      return data.keys().hasAll(['uid', 'theme']) &&
        data.uid is string && data.uid.size() <= 128 &&
        data.theme is string && data.theme.size() <= 100 &&
        (!data.keys().contains('recentlyViewed') || (data.recentlyViewed is list && data.recentlyViewed.size() <= 15));
    }

    // Validation Blueprint for CustomPosters (Pillar 2)
    function isValidCustomPoster(data) {
      return data.keys().hasAll([
        'id', 'title', 'subtitle', 'details', 'theme', 'bgType', 
        'bgValue', 'accentColor', 'textColor', 'fontTitle', 
        'fontSubtitle', 'align', 'geometricElement', 'category'
      ]) && 
      data.id is string && data.id.size() <= 128 &&
      data.title is string && data.title.size() <= 100 &&
      data.subtitle is string && data.subtitle.size() <= 100 &&
      data.details is string && data.details.size() <= 5000 &&
      data.theme is string && data.theme.size() <= 100 &&
      data.bgType is string && (data.bgType == 'image' || data.bgType == 'color' || data.bgType == 'gradient') &&
      data.bgValue is string && data.bgValue.size() <= 1000 &&
      data.accentColor is string && data.accentColor.size() <= 20 &&
      data.textColor is string && data.textColor.size() <= 20 &&
      data.fontTitle is string && data.fontTitle.size() <= 50 &&
      data.fontSubtitle is string && data.fontSubtitle.size() <= 50 &&
      data.align is string && (data.align == 'left' || data.align == 'center' || data.align == 'right') &&
      data.geometricElement is string && (data.geometricElement == 'circle' || data.geometricElement == 'lines' || data.geometricElement == 'grid' || data.geometricElement == 'border' || data.geometricElement == 'none') &&
      data.category is string && (data.category == 'fitness' || data.category == 'fashion' || data.category == 'minimalist' || data.category == 'offers' || data.category == 'all');
    }

    // Custom Posters Collection Rules
    match /custom_posters/{posterId} {
      // Anyone can read (get & list) custom posters to display in the grid
      allow read: if true;
      
      // Only the verified admin can create, update, or delete
      allow create: if isVerifiedAdmin() && isValidId(posterId) && isValidCustomPoster(request.resource.data);
      allow update: if isVerifiedAdmin() && isValidId(posterId) && isValidCustomPoster(request.resource.data);
      allow delete: if isVerifiedAdmin() && isValidId(posterId);
    }

    // System Audit Logs rules
    match /system_audit_logs/{logId} {
      // Only the verified admin can read or write logs
      allow read: if isVerifiedAdmin() && isValidId(logId);
      allow create: if isVerifiedAdmin() && isValidId(logId) && 
        request.resource.data.id is string &&
        request.resource.data.timestamp is number &&
        request.resource.data.action is string &&
        request.resource.data.details is string &&
        request.resource.data.adminEmail == 'puspharaj.m2003@gmail.com';
      
      // Updates and deletes are not allowed for audit log integrity
      allow update, delete: if false;
    }

    // Theme Configurations rules
    match /theme_configurations/{themeId} {
      allow read: if true;
      allow create, update: if isVerifiedAdmin() && isValidId(themeId) &&
        request.resource.data.id is string &&
        request.resource.data.name is string &&
        request.resource.data.isDark is bool &&
        request.resource.data.bg is string &&
        request.resource.data.text is string &&
        request.resource.data.accent is string &&
        request.resource.data.cardBg is string &&
        request.resource.data.borderRadius is string;
      allow delete: if isVerifiedAdmin() && isValidId(themeId);
    }

    // User Metadata Collection rules
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserMetadata(request.resource.data);
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserMetadata(request.resource.data);
      allow delete: if false; // Profiles shouldn't be deleted via client SDK directly
    }
  }
}
